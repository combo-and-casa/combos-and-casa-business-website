# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration (Client-Side Safe)
# ------------------------------------------------------------------------------
# These are safe to expose with NEXT_PUBLIC_ prefix
# The anon key is protected by Row Level Security (RLS) in Supabase
NEXT_PUBLIC_SUPABASE_PROJECT_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------------------------
# Paystack Payment Gateway
# ------------------------------------------------------------------------------
# Public key - Safe for client-side (use in frontend components)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Secret key - SERVER-SIDE ONLY (use in API routes/server actions only)
# ⚠️ NEVER add NEXT_PUBLIC_ prefix to secret keys!
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Currency - Supported: NGN, GHS, ZAR, USD (must match your Paystack account)
NEXT_PUBLIC_PAYSTACK_CURRENCY=GHS

# ------------------------------------------------------------------------------
# Site Configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here

# ------------------------------------------------------------------------------
# SMTP Email Configuration (SERVER-SIDE ONLY - Porkbun)
# ------------------------------------------------------------------------------
# Used for transactional emails (order confirmations, booking notifications, etc.)
# ⚠️ NEVER add NEXT_PUBLIC_ prefix - these are server-only credentials!

# Porkbun SMTP server settings
SMTP_HOST=mail.combosandcasagh.com
SMTP_PORT=587
# Use 587 for TLS (recommended) or 465 for SSL

# Your email credentials (purchased from Porkbun)
SMTP_USER=info@combosandcasagh.com
SMTP_PASS=your_email_password_here

# From address (should match SMTP_USER)
SMTP_FROM=info@combosandcasagh.com

# Admin email for notifications
ADMIN_EMAIL=info@combosandcasagh.com

# ------------------------------------------------------------------------------
# Optional: Other Email Services (if using alternatives)
# ------------------------------------------------------------------------------
# RESE ND_API_KEY=re_your_api_key_here
# SENDGRID_API_KEY=SG.your_api_key_here

# ------------------------------------------------------------------------------
# SECURITY REMINDERS:
# ------------------------------------------------------------------------------
# ✅ DO prefix with NEXT_PUBLIC_ - URLs, public keys, site config
# ❌ DON'T prefix with NEXT_PUBLIC_ - Secret keys, API keys, database passwords
# 🔒 Server-only variables are accessed in:
#    - API Routes (app/api/*)
#    - Server Components (without 'use client')
#    - Server Actions
# 🌐 NEXT_PUBLIC_ variables are bundled into client JavaScript
# ==============================================================================