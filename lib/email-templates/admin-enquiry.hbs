<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Enquiry - Combos & Casa Admin</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0A0A0A; color: #ffffff;">
  <table role="presentation" style="width: 100%; border-collapse: collapse; background-color: #0A0A0A;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" style="max-width: 600px; width: 100%; border-collapse: collapse; background-color: #1A1A1A; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
          
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #D4AF37 0%, #F4D03F 100%); padding: 30px; text-align: center;">
              <h1 style="margin: 0; color: #000000; font-size: 28px; font-weight: bold;">🔔 New Enquiry</h1>
              <p style="margin: 8px 0 0 0; color: #000000; font-size: 14px; opacity: 0.8;">{{businessUnit}} - Admin Notification</p>
            </td>
          </tr>

          <!-- Alert Badge -->
          <tr>
            <td style="padding: 30px 30px 20px 30px; background-color: #1A1A1A;">
              <div style="background-color: rgba(212, 175, 55, 0.2); border: 2px solid #D4AF37; border-radius: 12px; padding: 16px; text-align: center;">
                <p style="margin: 0; color: #D4AF37; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">⚡ Action Required</p>
              </div>
            </td>
          </tr>

          <!-- Customer Information -->
          <tr>
            <td style="padding: 0 30px 30px 30px; background-color: #1A1A1A;">
              <div style="background-color: rgba(255, 255, 255, 0.05); border-radius: 12px; padding: 24px; margin-bottom: 20px;">
                <h3 style="margin: 0 0 16px 0; color: #D4AF37; font-size: 18px; font-weight: 600;">📋 Customer Details</h3>
                <table style="width: 100%; border-collapse: collapse;">
                  <tr>
                    <td style="padding: 10px 0; color: rgba(255,255,255,0.6); font-size: 14px; width: 30%;">Name:</td>
                    <td style="padding: 10px 0; color: #ffffff; font-size: 14px; font-weight: 600;">{{customerName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Email:</td>
                    <td style="padding: 10px 0;">
                      <a href="mailto:{{customerEmail}}" style="color: #D4AF37; font-size: 14px; text-decoration: none;">{{customerEmail}}</a>
                    </td>
                  </tr>
                  {{#if customerPhone}}
                  <tr>
                    <td style="padding: 10px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Phone:</td>
                    <td style="padding: 10px 0;">
                      <a href="tel:{{customerPhone}}" style="color: #D4AF37; font-size: 14px; text-decoration: none;">{{customerPhone}}</a>
                    </td>
                  </tr>
                  {{/if}}
                  <tr>
                    <td style="padding: 10px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Reference:</td>
                    <td style="padding: 10px 0; color: #ffffff; font-size: 14px; font-family: monospace;">#{{referenceNumber}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Department:</td>
                    <td style="padding: 10px 0; color: #ffffff; font-size: 14px; text-transform: capitalize;">{{businessUnit}}</td>
                  </tr>
                </table>
              </div>

              <!-- Enquiry Details -->
              <div style="background-color: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 12px; padding: 24px; margin-bottom: 20px;">
                <h3 style="margin: 0 0 12px 0; color: #D4AF37; font-size: 18px; font-weight: 600;">📝 Subject</h3>
                <p style="margin: 0; color: #ffffff; font-size: 16px; font-weight: 600; line-height: 1.4;">{{subject}}</p>
              </div>

              <!-- Message Content -->
              <div style="background-color: rgba(255, 255, 255, 0.03); border-radius: 12px; padding: 24px; border-left: 4px solid #D4AF37;">
                <h3 style="margin: 0 0 12px 0; color: #D4AF37; font-size: 16px; font-weight: 600;">💬 Message:</h3>
                <p style="margin: 0; color: rgba(255,255,255,0.9); font-size: 14px; line-height: 1.8; white-space: pre-wrap;">{{message}}</p>
              </div>

              <!-- Action Buttons -->
              <div style="margin-top: 30px; text-align: center;">
                <table role="presentation" style="width: 100%;">
                  <tr>
                    <td style="padding: 0 0 12px 0;">
                      <a href="mailto:{{customerEmail}}?subject=Re: {{subject}} (Ref: %23{{referenceNumber}})" style="display: block; background: linear-gradient(135deg, #D4AF37 0%, #F4D03F 100%); color: #000000; text-decoration: none; padding: 16px 32px; border-radius: 8px; font-weight: 600; font-size: 15px;">
                        📧 Reply to Customer
                      </a>
                    </td>
                  </tr>
                  {{#if customerPhone}}
                  <tr>
                    <td style="padding: 0;">
                      <a href="tel:{{customerPhone}}" style="display: block; background-color: rgba(212, 175, 55, 0.2); color: #D4AF37; text-decoration: none; padding: 16px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; border: 1px solid rgba(212, 175, 55, 0.3);">
                        📞 Call Customer
                      </a>
                    </td>
                  </tr>
                  {{/if}}
                </table>
              </div>

              <!-- Timestamp -->
              <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center;">
                <p style="margin: 0; color: rgba(255,255,255,0.4); font-size: 12px;">
                  Received on {{submittedAt}}
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 30px; background-color: #0F0F0F; text-align: center;">
              <p style="margin: 0 0 8px 0; color: rgba(255,255,255,0.4); font-size: 12px;">
                Combos & Casa Admin System
              </p>
              <p style="margin: 0; color: rgba(255,255,255,0.4); font-size: 12px;">
                This is an automated notification. Please respond to the customer within 24-48 hours.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
