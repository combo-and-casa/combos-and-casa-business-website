<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership Activated - Combos & Casa</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0A0A0A; color: #ffffff;">
  <table role="presentation" style="width: 100%; border-collapse: collapse; background-color: #0A0A0A;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" style="max-width: 600px; width: 100%; border-collapse: collapse; background-color: #1A1A1A; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
          
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #D4AF37 0%, #F4D03F 100%); padding: 40px 30px; text-align: center;">
              <h1 style="margin: 0; color: #000000; font-size: 32px; font-weight: bold; letter-spacing: -0.5px;">Combos & Casa</h1>
              <p style="margin: 8px 0 0 0; color: #000000; font-size: 14px; opacity: 0.8;">Fresh & Fit Gym</p>
            </td>
          </tr>

          <!-- Success Message -->
          <tr>
            <td style="padding: 40px 30px; text-align: center; background-color: #1A1A1A;">
              <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #D4AF37 0%, #F4D03F 100%); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-center;">
                <span style="font-size: 48px;">💪</span>
              </div>
              <h2 style="margin: 0 0 12px 0; color: #ffffff; font-size: 28px; font-weight: bold;">Welcome to {{planName}}!</h2>
              <p style="margin: 0; color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.5;">
                Your membership is now active, <strong style="color: #D4AF37;">{{customerName}}</strong>!
              </p>
            </td>
          </tr>

          <!-- Membership Details -->
          <tr>
            <td style="padding: 0 30px 30px 30px; background-color: #1A1A1A;">
              <div style="background-color: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
                <h3 style="margin: 0 0 16px 0; color: #D4AF37; font-size: 18px; font-weight: 600;">Membership Information</h3>
                <table style="width: 100%; border-collapse: collapse;">
                  <tr>
                    <td style="padding: 8px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Membership ID:</td>
                    <td style="padding: 8px 0; color: #ffffff; font-size: 14px; text-align: right; font-weight: 600;">#{{membershipNumber}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Plan:</td>
                    <td style="padding: 8px 0; color: #D4AF37; font-size: 16px; text-align: right; font-weight: 700;">{{planName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Duration:</td>
                    <td style="padding: 8px 0; color: #ffffff; font-size: 14px; text-align: right; text-transform: capitalize;">{{duration}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Start Date:</td>
                    <td style="padding: 8px 0; color: #ffffff; font-size: 14px; text-align: right; font-weight: 600;">{{startDate}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Expiry Date:</td>
                    <td style="padding: 8px 0; color: #ffffff; font-size: 14px; text-align: right; font-weight: 600;">{{endDate}}</td>
                  </tr>
                </table>
              </div>

              <!-- Payment Confirmation -->
              <div style="background-color: rgba(0, 255, 100, 0.1); border-left: 4px solid #00FF64; border-radius: 8px; padding: 16px; margin-bottom: 24px;">
                <p style="margin: 0 0 8px 0; color: #00FF64; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">✓ Payment Confirmed</p>
                <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 14px;">
                  Amount: <strong style="color: #ffffff;">GH₵{{price}}</strong>
                  {{#if paymentReference}}
                  <br/>Reference: {{paymentReference}}
                  {{/if}}
                </p>
              </div>

              <!-- Membership Benefits -->
              <div style="background-color: rgba(255,255,255,0.03); border-radius: 12px; padding: 20px; margin-bottom: 24px;">
                <h4 style="margin: 0 0 12px 0; color: #D4AF37; font-size: 16px; font-weight: 600;">Your Benefits</h4>
                <ul style="margin: 0; padding-left: 20px; color: rgba(255,255,255,0.7); font-size: 13px; line-height: 1.8;">
                  <li>Unlimited gym access during operating hours</li>
                  <li>Free fitness assessment and personalized workout plan</li>
                  <li>Access to all cardio and strength training equipment</li>
                  <li>Complimentary locker usage</li>
                  <li>Free WiFi throughout facility</li>
                  <li>Member discounts on personal training sessions</li>
                  <li>Priority booking for fitness classes</li>
                  <li>Discount on Combos & Casa Restaurant orders</li>
                </ul>
              </div>

              <!-- Getting Started -->
              <div style="background-color: rgba(212, 175, 55, 0.1); border-left: 4px solid #D4AF37; border-radius: 8px; padding: 20px; margin-bottom: 24px;">
                <h4 style="margin: 0 0 12px 0; color: #D4AF37; font-size: 16px; font-weight: 600;">Getting Started</h4>
                <ul style="margin: 0; padding-left: 20px; color: rgba(255,255,255,0.8); font-size: 14px; line-height: 1.8;">
                  <li>Visit reception to collect your membership card</li>
                  <li>Schedule your free fitness assessment</li>
                  <li>Download our mobile app for class schedules</li>
                  <li>Join our WhatsApp community for tips & challenges</li>
                </ul>
              </div>

              <!-- Opening Hours -->
              <div style="background-color: rgba(255,255,255,0.05); border-radius: 8px; padding: 16px; margin-bottom: 24px;">
                <h4 style="margin: 0 0 12px 0; color: #ffffff; font-size: 15px; font-weight: 600;">🕐 Opening Hours</h4>
                <table style="width: 100%; border-collapse: collapse;">
                  <tr>
                    <td style="padding: 4px 0; color: rgba(255,255,255,0.6); font-size: 13px;">Monday - Friday:</td>
                    <td style="padding: 4px 0; color: #ffffff; font-size: 13px; text-align: right;">5:00 AM - 10:00 PM</td>
                  </tr>
                  <tr>
                    <td style="padding: 4px 0; color: rgba(255,255,255,0.6); font-size: 13px;">Saturday:</td>
                    <td style="padding: 4px 0; color: #ffffff; font-size: 13px; text-align: right;">6:00 AM - 9:00 PM</td>
                  </tr>
                  <tr>
                    <td style="padding: 4px 0; color: rgba(255,255,255,0.6); font-size: 13px;">Sunday:</td>
                    <td style="padding: 4px 0; color: #ffffff; font-size: 13px; text-align: right;">7:00 AM - 8:00 PM</td>
                  </tr>
                </table>
              </div>

              <!-- Contact Info -->
              <div style="text-align: center; padding: 24px; background-color: rgba(255,255,255,0.03); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                <p style="margin: 0 0 12px 0; color: rgba(255,255,255,0.6); font-size: 14px;">Questions about your membership?</p>
                <p style="margin: 0; color: #ffffff; font-size: 16px; font-weight: 600;">
                  📞 Gym Desk: <span style="color: #D4AF37;">+233 XX XXX XXXX</span>
                </p>
                <p style="margin: 8px 0 0 0; color: #ffffff; font-size: 16px; font-weight: 600;">
                  📧 Email: <span style="color: #D4AF37;">fitness@combosandcasagh.com</span>
                </p>
              </div>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td style="padding: 0 30px 40px 30px; background-color: #1A1A1A; text-align: center;">
              <a href="https://combosandcasagh.com/fresh&fit" style="display: inline-block; padding: 16px 32px; background: linear-gradient(135deg, #D4AF37 0%, #F4D03F 100%); color: #000000; font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 8px;">
                View Dashboard
              </a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 30px; background-color: #0F0F0F; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
              <p style="margin: 0 0 8px 0; color: rgba(255,255,255,0.4); font-size: 12px;">
                Let's achieve your fitness goals together! 💪
              </p>
              <p style="margin: 0; color: rgba(255,255,255,0.3); font-size: 11px;">
                © 2026 Combos & Casa. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
